# NEXUS Environment Configuration
# Copy this to .env and fill in your values

# ── Required for live mode ────────────────────────────────
# Leave empty to run in DEMO mode (fixture data, no real API calls)
GOOGLE_API_KEY=

# ── Auth ─────────────────────────────────────────────────
# Optional — leave empty for open access (dev/demo).
# Set to a random secret for production.
NEXUS_API_KEY=

# ── Demo mode ─────────────────────────────────────────────
# true  → fixture data, no real API calls needed
# false → uses GOOGLE_API_KEY, SUPABASE_*, TAVILY_API_KEY etc.
DEMO_MODE=true

# ── Server ────────────────────────────────────────────────
PORT=8000

# ── Supabase (Layer 2/3/4 persistence) ───────────────────
# Required for memory persistence and real-time traces.
# Create a free project at https://supabase.com
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Search (Atlas agent, optional in demo mode) ───────────
# Get a free key at https://tavily.com
TAVILY_API_KEY=
# Alternative: https://api.search.brave.com
BRAVE_API_KEY=

# ── External integrations (optional) ─────────────────────
OPENWEATHER_API_KEY=
NOTION_TOKEN=
GMAIL_API_KEY=

# ── CORS (comma-separated) ────────────────────────────────
# Add your frontend origin(s) if deploying separately.
ALLOWED_ORIGINS=http://localhost:5500,http://localhost:8000,http://127.0.0.1:5500
